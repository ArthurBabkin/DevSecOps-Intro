                "text": "CVE-2026-21637"
              },
              "helpUri": "https://scout.docker.com/v/CVE-2026-21637?s=docker&n=node&t=generic&vr=%3E%3D22.0.0%2C%3C22.22.0",
              "help": {
                "text": "\n",
                "markdown": "> \n\n|                                          |\n|Package         pkg:generic/node@22.18.0  |\n|Affected range  >=22.0.0,<22.22.0         |\n|Fixed version   22.22.0                   |\n"
