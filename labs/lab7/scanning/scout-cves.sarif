                "cvssV3_severity": "HIGH",
                "cvssV3_vector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H",
                "fixed_version": "3.0.3",
                "purls": [
                  "pkg:npm/braces@2.3.2"
                ],
