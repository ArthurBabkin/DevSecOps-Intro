            {
              "id": "CVE-2018-16487",
              "name": "OsPackageVulnerability",
              "shortDescription": {
                "text": "CVE-2018-16487: Uncontrolled Resource Consumption"
              },
              "helpUri": "https://scout.docker.com/v/CVE-2018-16487?s=github&n=lodash&t=npm&vr=%3C4.17.11",
              "help": {
                "text": "Versions of `lodash` before 4.17.11 are vulnerable to prototype pollution. \n\nThe vulnerable functions are 'defaultsDeep', 'merge', and 'mergeWith' which allow a malicious user to modify the prototype of `Object` via `{constructor: {prototype: {...}}}` causing the addition or modification of an existing property that will exist on all objects.\n\n\n\n\n## Recommendation\n\nUpdate to version 4.17.11 or later.\n",
                "markdown": "> Versions of `lodash` before 4.17.11 are vulnerable to prototype pollution. \n\nThe vulnerable functions are 'defaultsDeep', 'merge', and 'mergeWith' which allow a malicious user to modify the prototype of `Object` via `{constructor: {prototype: {...}}}` causing the addition or modification of an existing property that will exist on all objects.\n\n\n\n\n## Recommendation\n\nUpdate to version 4.17.11 or later.\n\n|                                      |\n|Package         pkg:npm/lodash@2.4.2  |\n|Affected range  <4.17.11              |\n|Fixed version   4.17.11               |\n"
              },
              "properties": {
                "affected_version": "<4.17.11",
                "cvssV3_severity": "HIGH",
                "fixed_version": "4.17.11",
                "purls": [
                  "pkg:npm/lodash@2.4.2"
                ],
                "security-severity": "7.1",
                "tags": [
                  "HIGH"
                ]
              }
